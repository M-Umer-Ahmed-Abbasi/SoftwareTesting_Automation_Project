{
  "name": "spree-playwright-framework",
  "version": "1.0.0",
  "description": "Playwright JS Automation Framework for Spree Commerce with Allure Reporting",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:login": "npx playwright test tests/login.spec.js --headed",
    "test:search": "npx playwright test tests/productSearch.spec.js --headed",
    "test:checkout": "npx playwright test tests/checkout.spec.js --headed",
    "test:account": "npx playwright test tests/accountNavigation.spec.js --headed",
    "test:nonfunctional": "npx playwright test tests/nonFunctional.spec.js --headed",
    "test:e2e": "npx playwright test tests/e2e.spec.js --headed",
    "test:chromium": "npx playwright test --project=chromium --headed",
    "test:firefox": "npx playwright test --project=firefox --headed",
    "test:report": "npx playwright test && npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:allure": "npx playwright test && npm run allure:serve"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.29.0"
  },
  "dependencies": {
    "winston": "^3.13.0",
    "dotenv": "^16.4.5"
  }
}
